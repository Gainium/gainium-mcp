{
  "name": "gainium-mcp",
  "version": "3.2.3",
  "mcpName": "io.gainium/gainium-mcp",
  "type": "module",
  "description": "MCP server for Gainium — manage trading bots, deals, and balances via AI assistants",
  "main": "dist/server.js",
  "bin": {
    "gainium-mcp": "dist/server.js"
  },
  "files": [
    "dist/server.js",
    "dist/gainium-client.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "start": "node -r dotenv/config dist/server.js",
    "dev": "tsc && node -r dotenv/config dist/server.js",
    "prepublishOnly": "npm run build",
    "pm:start": "pm2 start ecosystem.config.cjs ",
    "pm:stop": "pm2 stop ecosystem.config.cjs ",
    "pm:restart": "pm2 restart ecosystem.config.cjs ",
    "pm:delete": "pm2 delete ecosystem.config.cjs "
  },
  "keywords": [
    "mcp",
    "gainium",
    "trading",
    "bots",
    "crypto",
    "model-context-protocol",
    "claude",
    "ai"
  ],
  "author": "Gainium",
  "license": "MIT",
  "homepage": "https://gainium.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gainium/gainium-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/gainium/gainium-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  }
}
