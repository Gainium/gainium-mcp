# ── Local stdio mode (default) ─────────────────────────────────────────────
GAINIUM_API_KEY=your_api_key_here
GAINIUM_API_SECRET=your_api_secret_here
# Optional: defaults to https://api.gainium.io
# GAINIUM_API_BASE_URL=https://api.gainium.io

# ── Hosted HTTP mode ───────────────────────────────────────────────────────
# GAINIUM_MCP_TRANSPORT=http
# GAINIUM_MCP_HOST=0.0.0.0
# GAINIUM_MCP_PORT=3000

# ── OAuth 2.1 protected-resource mode (Claude connector directory) ─────────
# Set these (in HTTP mode) to require OAuth instead of X-API-Key headers.
# Presence of GAINIUM_OAUTH_ISSUER + MCP_INTROSPECTION_SECRET enables it.
# GAINIUM_OAUTH_ISSUER=https://app.gainium.io
# Defaults to <issuer>/oauth/introspect if unset:
# GAINIUM_INTROSPECTION_URL=https://app.gainium.io/oauth/introspect
# Shared secret presented to the auth server's introspection endpoint
# (must match MCP_INTROSPECTION_SECRET on the main-app backend):
# MCP_INTROSPECTION_SECRET=change-me
# Public base URL used in resource metadata (else derived from request host):
# GAINIUM_MCP_PUBLIC_URL=https://mcp.gainium.io

# ── OpenAI Apps submission ─────────────────────────────────────────────────
# Domain-verification token from the OpenAI Apps submission form. When set, the
# server serves it (plain text) at /.well-known/openai-apps-challenge.
# OPENAI_APPS_CHALLENGE_TOKEN=your_challenge_token_here
